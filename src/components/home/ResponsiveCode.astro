---
import { Code } from '@astrojs/starlight/components';

interface Props {
  code: string;
  lang: string;
}

const { code, lang } = Astro.props;
---

<div class="responsive-code">
  <Code code={code} lang={lang} />
</div>

<style>
  .responsive-code {
    min-width: 0;
    max-width: 100%;
  }

  .responsive-code :global(.expressive-code),
  .responsive-code :global(.frame),
  .responsive-code :global(pre) {
    max-width: 100%;
  }

  .responsive-code :global(.frame) {
    overflow: hidden;
  }

  .responsive-code :global(pre) {
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
  }
</style>
