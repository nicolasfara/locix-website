---
import { Code } from "@astrojs/starlight/components";

const pillars = [
  {
    label: 'Multitier',
    title: 'Where computation lives',
    body: 'Place code and data safely across peers enabling cross-tier interactions without boilerplate or breaking abstractions.',
    codeExample: `
multitier:
  val data = on[Server]:
    query("SELECT * FROM users")
  on[Client]:
    render(asLocal(data)) 
`
  },
  {
    label: 'Choreography',
    title: 'Deadlock-free peer interaction',
    body: 'Express cross-host communication in program order so protocols remain visible instead of scattering across handlers.',
    codeExample: `
choreography:
  val ping = on[Pinger]("ping")
  val onPonger =
      comm[Pinger, Ponger](ping)
  on[Ponger] { take(onPonger) }
`
  },
  {
    label: 'Collective',
    title: 'Collective-adaptive behaviors',
    body: 'Model device ensembles as collective computations over local observations, time, and interactions with nearby peers.',
    codeExample: `
collective[Phone](1.second):
  rep(PositiveInfinity): prev =>
    mux(isSource) { 0.0 } {
      (nbr(prev) + nbrRange).min
    }
`
  },
];

const foundationStates = [
  {
    title: 'Capabilities',
    body: 'Capabilities make access to each programming model explicit, so paradigm-specific operations stay deliberate, controlled, and visible in the structure of the program.',
    mark: ['Placement', 'Choreography', 'Multitier', 'Collective'],
  },
  {
    title: 'Placement Types',
    body: 'Placement types define where data belongs and how values are situated across peers, keeping location explicit in the type structure of the program.',
    mark: [1, 2, 'Data on Alice'],
  },
];

const placementTypesCapabilities = `type Alice <: { type Tie <: Bob }
type Bob <: { type Tie <: Alice }

def example(input: Data on Alice)(using
    Placement, Choreography, Multitier, Collective
) =
  val choreoResult = choreography { /*...*/ }
  val multitierResult = multitier { /*...*/ }
  val collectiveResult = collective(1.second) { /*...*/ }
`
---

<section class="thesis-foundation home-card not-content" data-foundation-switcher>
  <span class="home-eyebrow">Shared foundation</span>
  <div class="thesis-foundation__content">
    <div class="thesis-foundation__copy">
      <div class="thesis-foundation__copy-stage">
        {
          foundationStates.map(({ title, body }, index) => (
            <section
              class="thesis-foundation__panel"
              data-foundation-copy
              data-active={index === 0 ? 'true' : 'false'}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <h3 class="home-title">{title}</h3>
              <p class="home-body">{body}</p>
            </section>
          ))
        }
      </div>
      <div class="thesis-foundation__dots" aria-label="Shared foundation scenarios">
        {
          foundationStates.map(({ title }, index) => (
            <button
              type="button"
              class="thesis-foundation__dot"
              data-foundation-dot
              aria-label={`Show ${title.toLowerCase()}`}
              aria-pressed={index === 0 ? 'true' : 'false'}
            />
          ))
        }
      </div>
    </div>
    <div class="thesis-foundation__example">
      <div class="thesis-foundation__code-stage">
        {
          foundationStates.map(({ mark }, index) => (
            <div
              class="thesis-foundation__panel"
              data-foundation-code
              data-active={index === 0 ? 'true' : 'false'}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <div class="home-code">
                <Code code={placementTypesCapabilities} lang="scala" mark={mark} />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<section class="thesis-pillars home-grid not-content">
  {
    pillars.map(({ label, title, body, codeExample }) => (
      <article class="home-card">
        <span class="home-eyebrow">{label}</span>
        <h3 class="home-title">{title}</h3>
        <p class="home-body">{body}</p>
        {
          codeExample && (
            <div class="home-code">
              <Code code={codeExample} lang="scala" />
            </div>
          )
        }
      </article>
    ))
  }
</section>

<style>
  .thesis-foundation {
    margin-top: 1.5rem;
    --home-card-accent: color-mix(in srgb, #79c8b2 18%, transparent);
    --home-card-accent-dark: color-mix(in srgb, #79c8b2 18%, transparent);
    --home-card-accent-size: 38%;
    --home-card-bg-from: color-mix(in srgb, var(--sl-color-bg) 92%, white);
  }

  .thesis-foundation__content,
  .thesis-foundation__copy {
    display: grid;
    gap: 1rem;
  }

  .thesis-foundation__content {
    align-items: start;
  }

  .thesis-foundation__copy,
  .thesis-foundation__example,
  .thesis-foundation__panel {
    min-width: 0;
  }

  .thesis-foundation__copy {
    align-content: start;
  }

  .thesis-foundation__copy-stage,
  .thesis-foundation__code-stage {
    display: grid;
  }

  .thesis-foundation__panel {
    grid-area: 1 / 1;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(0.2rem);
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .thesis-foundation__panel[data-active='true'] {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateY(0);
  }

  .thesis-foundation__scenario-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .thesis-pillars {
    margin-top: 1rem;
  }

  @media (min-width: 48rem) {
    .thesis-pillars {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .thesis-pillars .home-code {
    margin-top: 0.95rem;
  }

  @media (min-width: 60rem) {
    .thesis-foundation__content {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }
  }

  .thesis-foundation__copy .home-body {
    margin-top: 0.65rem;
  }

  .thesis-foundation__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
  }

  .thesis-foundation__dot {
    width: 0.72rem;
    height: 0.72rem;
    border: 0;
    border-radius: 9999px;
    padding: 0;
    background: color-mix(in srgb, var(--sl-color-gray-4) 45%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-gray-5) 35%, transparent);
    cursor: pointer;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .thesis-foundation__dot:hover,
  .thesis-foundation__dot:focus-visible {
    transform: scale(1.08);
  }

  .thesis-foundation__dot:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--sl-color-text-accent) 60%, white);
    outline-offset: 2px;
  }

  .thesis-foundation__dot[aria-pressed='true'] {
    background: color-mix(in srgb, var(--sl-color-text-accent) 75%, white);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--sl-color-text-accent) 35%, transparent);
  }

  .thesis-foundation .home-code {
    margin-top: 0;
  }
</style>

<script is:inline>
  for (const root of document.querySelectorAll('[data-foundation-switcher]')) {
    const dots = Array.from(root.querySelectorAll('[data-foundation-dot]'));
    const copyPanels = Array.from(root.querySelectorAll('[data-foundation-copy]'));
    const codePanels = Array.from(root.querySelectorAll('[data-foundation-code]'));

    if (!dots.length || copyPanels.length !== codePanels.length || !copyPanels.length) continue;

    let activeIndex = dots.findIndex((dot) => dot.getAttribute('aria-pressed') === 'true');

    if (activeIndex < 0) activeIndex = 0;

    const syncPanels = (panels, index) => {
      panels.forEach((panel, panelIndex) => {
        const isActive = panelIndex === index;
        panel.dataset.active = isActive ? 'true' : 'false';
        panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
      });
    };

    const applyState = (index) => {
      activeIndex = index;

      dots.forEach((dot, dotIndex) => {
        dot.setAttribute('aria-pressed', dotIndex === index ? 'true' : 'false');
      });

      syncPanels(copyPanels, index);
      syncPanels(codePanels, index);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        applyState(index);
      });
    });

    applyState(activeIndex);
  }
</script>
