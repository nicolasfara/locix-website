---
import BrandName from '../BrandName.astro';
---

<section class="evidence-strip home-grid home-grid--stats not-content">
  <article class="home-card home-card--quiet home-card--tight">
    <strong class="home-stat-value">3</strong>
    <span class="home-stat-copy">Paradigms integrated into a coherent, capability-based, type-safe API</span>
  </article>
  <article class="home-card home-card--quiet home-card--tight">
    <strong class="home-stat-value">45+</strong>
    <span class="home-stat-copy">Use cases from <em>choreography</em>, <em>multitier</em>, and <em>aggregate programming</em> ported in <BrandName /></span>
  </article>
  <!-- <article class="home-card home-card--quiet home-card--tight">
    <strong class="home-stat-value">1</strong>
    <span class="home-stat-copy">Formalized core with type soundness for placed values and cross-paradigm interaction</span>
  </article> -->
  <article class="home-card home-card--quiet home-card--tight">
    <strong class="home-stat-value">2</strong>
    <span class="home-stat-copy">Case studies demonstrating the integration of the three paradigms: <a href="/examples/cityevt/">CityEvt</a> and <a href="/examples/nebula/">Nebula</a></span>
  </article>
</section>

<style>
  .evidence-strip {
    margin-top: clamp(2rem, 4vw, 3rem);
  }
</style>
