---
const publications = [
  {
    label: 'Placeholder preprint',
    title: 'A Placeholder Title for a Modern Distributed System Framework',
    authors: 'Author One and Author Two and Author Three',
    venue: 'Venue or Journal Name',
    year: '2026',
    abstract:
      'Replace this placeholder with the short publication summary you want visitors to read before copying the citation.',
    bibtex: `@inproceedings{placeholder2026unified,
  title     = {A Placeholder Title for a Modern Distributed System Framework},
  author    = {Author One and Author Two and Author Three},
  booktitle = {Venue or Journal Name},
  year      = {2026},
  note      = {Placeholder entry}
}`,
  },
  {
    label: 'Placeholder article',
    title: 'Another Placeholder Paper on Capabilities and Placement Types',
    authors: 'Author A and Author B',
    venue: 'Proceedings Placeholder',
    year: '2025',
    abstract:
      'Use this card for a second publication, an accepted version, or a companion paper once the real citation details are ready.',
    bibtex: `@article{placeholder2025capabilities,
  title   = {Another Placeholder Paper on Capabilities and Placement Types},
  author  = {Author A and Author B},
  journal = {Proceedings Placeholder},
  year    = {2025},
  note    = {Placeholder entry}
}`,
  },
  {
    label: 'Placeholder thesis',
    title: 'Placeholder Thesis on Typed Cross-Paradigm Composition',
    authors: 'Student Name',
    venue: 'University Name',
    year: '2024',
    abstract:
      'This can also hold a thesis, tech report, workshop version, or artifact paper while the final bibliography is still in progress.',
    bibtex: `@phdthesis{placeholder2024thesis,
  title  = {Placeholder Thesis on Typed Cross-Paradigm Composition},
  author = {Student Name},
  school = {University Name},
  year   = {2024},
  note   = {Placeholder entry}
}`,
  },
];
---

<section class="publications not-content">
  {
    publications.map(({ label, title, authors, venue, year, abstract, bibtex }) => (
      <article class="publication-band" data-bib-entry={encodeURIComponent(bibtex)}>
        <div class="publication-entry__content">
          <div class="publication-entry__header">
            <span class="publication-entry__label">{label}</span>
            <button
              type="button"
              class="publication-card__copy"
              data-bib-copy
              aria-label="Copy BibTeX citation"
              title="Copy BibTeX citation"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" class="publication-card__copy-icon">
                <path
                  d="M8.75 8.75h8.5a2 2 0 0 1 2 2v8.5a2 2 0 0 1-2 2h-8.5a2 2 0 0 1-2-2v-8.5a2 2 0 0 1 2-2Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.6"
                />
                <path
                  d="M5.75 15.25h-.5a2 2 0 0 1-2-2v-8.5a2 2 0 0 1 2-2h8.5a2 2 0 0 1 2 2v.5"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.6"
                />
              </svg>
            </button>
          </div>

          <p class="publication-entry__citation">
            <span class="publication-entry__authors">{authors}, </span>
            <span class="publication-entry__title">"{title}," </span>
            <span class="publication-entry__venue">{venue}, </span>
            <span class="publication-entry__year">{year}.</span>
          </p>

          <p class="publication-entry__abstract">{abstract}</p>
          <p class="publication-card__status" data-bib-status aria-live="polite"></p>
        </div>
      </article>
    ))
  }
</section>

<style>
  .publications {
    --publication-font:
      ui-serif,
      Charter,
      'Bitstream Charter',
      'Iowan Old Style',
      'Palatino Linotype',
      'Book Antiqua',
      'Noto Serif',
      serif;
    display: grid;
    margin-top: 0.75rem;
    border-top: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 42%, transparent);
  }

  .publication-band {
    min-width: 0;
    padding: 1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 28%, transparent);
    font-family: var(--publication-font);
  }

  .publication-entry__content {
    min-width: 0;
  }

  .publication-entry__header {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    justify-content: space-between;
  }

  .publication-entry__label {
    color: var(--sl-color-gray-2);
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .publication-card__copy {
    flex-shrink: 0;
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 32%, transparent);
    border-radius: 0.35rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    padding: 0;
    background: color-mix(in srgb, var(--sl-color-bg) 90%, white);
    color: var(--sl-color-text);
    cursor: pointer;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease;
  }

  .publication-card__copy-icon {
    width: 1rem;
    height: 1rem;
  }

  .publication-card__copy:hover,
  .publication-card__copy:focus-visible {
    border-color: color-mix(in srgb, var(--sl-color-text-accent) 34%, transparent);
    background: color-mix(in srgb, var(--sl-color-text-accent) 8%, white);
  }

  .publication-card__copy:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--sl-color-text-accent) 45%, white);
    outline-offset: 2px;
  }

  .publication-entry__citation {
    margin: 0.4rem 0 0;
    color: var(--sl-color-text);
    font-size: 1rem;
    line-height: 1.55;
  }

  .publication-entry__authors,
  .publication-entry__year {
    color: var(--sl-color-text);
  }

  .publication-entry__title {
    color: var(--sl-color-text);
  }

  .publication-entry__venue {
    color: var(--sl-color-gray-2);
    font-style: italic;
  }

  .publication-entry__abstract {
    margin: 0.45rem 0 0;
    color: var(--sl-color-gray-2);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .publication-card__status {
    display: block;
    margin: 0.45rem 0 0;
    font-size: 0.72rem;
    font-weight: 700;
    font-family: var(--font-sans);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #4f9c6b;
    min-height: 1em;
  }

  @media (max-width: 42rem) {
    .publication-band {
      padding: 0.9rem 0;
    }

    .publication-entry__header {
      flex-direction: column;
      align-items: start;
    }

    .publication-card__copy {
      width: fit-content;
    }

    .publication-entry__citation {
      margin-top: 0.2rem;
    }
  }
</style>

<script is:inline>
  const copyBibText = async (text) => {
    if (navigator.clipboard?.writeText) {
      await navigator.clipboard.writeText(text);
      return;
    }

    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.setAttribute('readonly', '');
    textarea.style.position = 'absolute';
    textarea.style.left = '-9999px';
    document.body.append(textarea);
    textarea.select();
    document.execCommand('copy');
    textarea.remove();
  };

  for (const card of document.querySelectorAll('.publication-band')) {
    const button = card.querySelector('[data-bib-copy]');
    const status = card.querySelector('[data-bib-status]');

    if (!(card instanceof HTMLElement) || !(button instanceof HTMLButtonElement) || !status) continue;

    const bibtex = decodeURIComponent(card.dataset.bibEntry ?? '').trim();
    const defaultAriaLabel = button.getAttribute('aria-label') ?? 'Copy BibTeX citation';
    const defaultTitle = button.getAttribute('title') ?? defaultAriaLabel;

    button.addEventListener('click', async () => {
      try {
        await copyBibText(bibtex);
        button.setAttribute('aria-label', 'BibTeX copied');
        button.setAttribute('title', 'BibTeX copied');
        status.textContent = 'Copied to clipboard';
      } catch {
        button.setAttribute('aria-label', 'Copy failed');
        button.setAttribute('title', 'Copy failed');
        status.textContent = 'Clipboard unavailable';
      }

      window.setTimeout(() => {
        button.setAttribute('aria-label', defaultAriaLabel);
        button.setAttribute('title', defaultTitle);
        status.textContent = '';
      }, 1800);
    });
  }
</script>
