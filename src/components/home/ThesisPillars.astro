---
const pillars = [
  {
    label: 'Multitier',
    title: 'Where computation lives',
    body: 'Place code and data explicitly across peers such as clients, servers, dashboards, edge nodes, and devices.',
  },
  {
    label: 'Choreography',
    title: 'Deadlock-free peer interaction',
    body: 'Describe cross-host communication in program order instead of scattering message handlers, callbacks, and protocol state throughout the codebase.',
  },
  {
    label: 'Aggregate',
    title: 'Collective-adaptive behaviors',
    body: 'Model ensembles of devices as collective computations over local observations, time, and neighboring peers.',
  },
  {
    label: 'Shared foundation',
    title: 'Capabilities + placement types',
    body: "The paper's core idea is that paradigm-specific operations can be guarded by capabilities, while placement types regulate where values live and how they move between peers.",
    featured: true,
  },
];
---

<section class="thesis-pillars home-grid not-content">
  {
    pillars.map(({ label, title, body, featured }) => (
      <article class:list={['home-card', { 'thesis-pillars__foundation': featured }]}>
        <span class="home-eyebrow">{label}</span>
        <h3 class="home-title">{title}</h3>
        <p class="home-body">{body}</p>
      </article>
    ))
  }
</section>

<style>
  .thesis-pillars {
    margin-top: 1.5rem;
  }

  @media (min-width: 48rem) {
    .thesis-pillars {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .thesis-pillars__foundation {
    order: -1;
    grid-column: 1 / -1;
    --home-card-accent: color-mix(in srgb, #79c8b2 18%, transparent);
    --home-card-accent-dark: color-mix(in srgb, #79c8b2 18%, transparent);
    --home-card-accent-size: 38%;
    --home-card-bg-from: color-mix(in srgb, var(--sl-color-bg) 92%, white);
  }
</style>
