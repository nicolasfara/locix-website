---
import ResponsiveCode from './ResponsiveCode.astro';

const cityEvtExample = `def cityEvtApp(using Network, Placement, Multitier, Choreography, Collective) =
  val registrationData = on[Smartphone]:
    val username = peerAddress.asInstanceOf[String]
    (username, s"$username@example.com")

  val token = userRegistration(registrationData)
  recommendation(token)
  crowdMonitoring`;
---

<section class="case-study-showcase home-card not-content">
  <div class="case-study-showcase__copy">
    <span class="home-eyebrow">Mixed-paradigm example</span>
    <h3 class="home-title">CityEvt is the shortest path to the thesis.</h3>
    <p class="home-body">
      CityEvt combines three subsystems in one program: multitier registration across smartphones
      and cloud, a choreographic recommendation workflow between edge and cloud, and collective
      crowd monitoring over nearby phones. It is the clearest public example of why the research
      line is about composition rather than isolated DSL features.
    </p>
    <div class="case-study-flow">
      <article class="case-study-flow__step">
        <strong>Registration</strong>
        <span>Multitier handoff from phones to cloud</span>
      </article>
      <article class="case-study-flow__step">
        <strong>Recommendations</strong>
        <span>Choreographic protocol across edge and cloud</span>
      </article>
      <article class="case-study-flow__step">
        <strong>Crowd monitoring</strong>
        <span>Collective sensing over neighboring smartphones</span>
      </article>
    </div>
  </div>
  <div class="case-study-showcase__code">
    <ResponsiveCode code={cityEvtExample} lang="scala" />
  </div>
</section>

<style>
  .case-study-showcase {
    --home-card-radius: 1.75rem;
    --home-card-padding: clamp(1.25rem, 3vw, 2rem);
    --home-card-accent: color-mix(in srgb, var(--sl-color-text-accent) 10%, transparent);
    --home-card-accent-dark: color-mix(in srgb, var(--sl-color-text-accent) 16%, transparent);
    --home-card-shadow:
      0 1px 0 color-mix(in srgb, white 5%, transparent) inset,
      0 28px 60px -40px color-mix(in srgb, black 42%, transparent);
    --home-card-shadow-dark:
      0 1px 0 color-mix(in srgb, white 10%, transparent) inset,
      0 28px 60px -40px color-mix(in srgb, black 72%, transparent);
    --home-card-accent-position: top right;
    display: grid;
    gap: 1.25rem;
    margin-top: 1rem;
    --home-card-accent-size: 36%;
  }

  .case-study-showcase__copy,
  .case-study-showcase__code {
    min-width: 0;
  }

  @media (min-width: 60rem) {
    .case-study-showcase {
      grid-template-columns: minmax(0, 1fr) minmax(22rem, 0.92fr);
      align-items: start;
    }
  }

  .case-study-flow {
    display: grid;
    gap: 0.9rem;
    margin-top: 1.15rem;
  }

  .case-study-flow__step {
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 32%, transparent);
    border-radius: 1rem;
    padding: 0.9rem 1rem;
    background: color-mix(in srgb, var(--sl-color-bg) 90%, white);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  :global([data-theme='dark']) .case-study-flow__step {
    background: color-mix(in srgb, var(--sl-color-bg) 94%, white);
  }

  .case-study-flow span {
    color: var(--sl-color-gray-2);
    font-size: 0.95rem;
    line-height: 1.4;
  }
</style>
