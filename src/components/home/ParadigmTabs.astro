---
import { Tabs, TabItem } from '@astrojs/starlight/components';
import ResponsiveCode from './ResponsiveCode.astro';

const choreographyExample = `object PingPong:
  type Pinger <: { type Tie <: Single[Ponger] }
  type Ponger <: { type Tie <: Single[Pinger] }

  def program(using Network, Placement, Choreography) = Choreography:
    val pingOnPinger = on[Pinger]:
      "ping"

    val pingOnPonger = comm[Pinger, Ponger](pingOnPinger)

    val pongOnPonger = on[Ponger]:
      s"\${take(pingOnPonger)} -> pong"

    val pongOnPinger = comm[Ponger, Pinger](pongOnPonger)`;

const multitierExample = `object MasterWorker:
  type Master <: { type Tie <: Multiple[Worker] }
  type Worker <: { type Tie <: Single[Master] }

  def program(using Network, Placement, Multitier) = Multitier:
    val allocation = on[Master]:
      allocateTasks

    val workerResults = on[Worker]:
      val localAddress = peerAddress
      asLocal(allocation)
        .filter(_._1 == localAddress)
        .flatMap(_._2)
        .map(_.exec())

    on[Master]:
      asLocalAll(workerResults).values.flatMap(_.toList).toList`;

const collectiveExample = `object AggregateCounter:
  type Smartphone <: { type Tie <: Multiple[Smartphone] }

  def program(using Network, Placement, Collective) =
    val counter = Collective[Smartphone](1.second):
      rep(0)(_ + 1)

    on[Smartphone]:
      take(counter).subscribe: value =>
        println(s"Device \${peerAddress} has count: $value")`;
---

<section class="models-showcase home-card home-panel not-content">
  <div class="models-showcase__intro">
    <span class="home-eyebrow">Runnable examples from the main repository</span>
    <h3 class="home-title">Three paradigms remain distinct, but they no longer live in separate worlds.</h3>
    <p class="home-body">
      The isolated examples below still matter because each paradigm keeps its own vocabulary.
      MpaCT is interesting because these pieces can also be composed in the same typed framework.
    </p>
  </div>

  <div class="models-showcase__tabs">
    <Tabs syncKey="mpact-paradigms">
      <TabItem label="Choreography">
        <p class="models-showcase__tab-copy home-lead">
          Use explicit communication terms such as <code>comm</code>, <code>broadcast</code>, and
          <code>gather</code> when the interaction protocol itself is the central object you want to read
          and reason about.
        </p>
        <ResponsiveCode code={choreographyExample} lang="scala" />
      </TabItem>
      <TabItem label="Multitier">
        <p class="models-showcase__tab-copy home-lead">
          Use <code>on</code>, <code>asLocal</code>, and <code>asLocalAll</code> when architectural placement
          and typed cross-tier data access are the key concerns.
        </p>
        <ResponsiveCode code={multitierExample} lang="scala" />
      </TabItem>
      <TabItem label="Collective">
        <p class="models-showcase__tab-copy home-lead">
          Use <code>rep</code>, <code>nbr</code>, and related collective operators when local device state
          should evolve from neighboring context rather than point-to-point protocols.
        </p>
        <ResponsiveCode code={collectiveExample} lang="scala" />
      </TabItem>
    </Tabs>
  </div>
</section>

<style>
  .models-showcase {
    margin-top: clamp(2.5rem, 4vw, 4rem);
    --home-card-padding: clamp(1.25rem, 3vw, 2.25rem);
    --home-card-accent-size: 30%;
    --home-card-bg-from: color-mix(in srgb, var(--sl-color-bg) 94%, white);
    --home-card-bg-to: color-mix(in srgb, var(--sl-color-bg) 97%, black);
  }

  .models-showcase__intro {
    max-width: 50rem;
    margin-bottom: 1.5rem;
  }

  .models-showcase__tabs {
    min-width: 0;
  }

  .models-showcase__tabs :global([role='tablist']) {
    gap: 0.75rem;
    border-bottom: 0;
    flex-wrap: wrap;
  }

  .models-showcase__tabs :global(.tab > [role='tab']) {
    border: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 36%, transparent);
    border-radius: 9999px;
    box-shadow: none;
    background: color-mix(in srgb, var(--sl-color-bg) 88%, white);
    color: var(--sl-color-gray-2);
    padding: 0.55rem 1rem;
    font-weight: 600;
  }

  .models-showcase__tabs :global(.tab > [role='tab'][aria-selected='true']) {
    background: color-mix(in srgb, var(--sl-color-text-accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--sl-color-text-accent) 36%, transparent);
    color: var(--sl-color-white);
  }

  :global([data-theme='dark']) .models-showcase__tabs :global(.tab > [role='tab']) {
    background: color-mix(in srgb, var(--sl-color-bg) 94%, white);
  }

  .models-showcase__tabs :global([role='tabpanel']) {
    min-width: 0;
    margin-top: 1.25rem;
  }
</style>
